<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Store header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="BUTIK KASIR"
        android:textColor="#E91E63"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="2dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Toko Fashion Pilihan"
        android:textColor="#757575"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F8BBD0"
        android:layout_marginBottom="12dp" />

    <!-- Transaction info rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="5dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="No. Transaksi"
            android:textColor="#757575"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/strukTvId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="5dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tanggal"
            android:textColor="#757575"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/strukTvTanggal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Kasir"
            android:textColor="#757575"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/strukTvKasir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F8BBD0"
        android:layout_marginBottom="12dp" />

    <!-- Detail belanja -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DETAIL BELANJA"
        android:textColor="#757575"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:id="@+id/strukItemContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="14dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F8BBD0"
        android:layout_marginBottom="12dp" />

    <!-- Total -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="14dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TOTAL"
            android:textColor="#212121"
            android:textSize="15sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/strukTvTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E91E63"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F8BBD0"
        android:layout_marginBottom="12dp" />

    <!-- Payment info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="5dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Metode Bayar"
            android:textColor="#757575"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/strukTvMetode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/strukLayoutBayar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="5dp"
        android:visibility="gone">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Uang Diterima"
            android:textColor="#757575"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/strukTvBayar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#212121"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/strukLayoutKembalian"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Kembalian"
            android:textColor="#757575"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/strukTvKembalian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#388E3C"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Footer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F8BBD0"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="14dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Terima kasih telah berbelanja!"
        android:textColor="#E91E63"
        android:textSize="12sp"
        android:textStyle="italic" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Simpan struk ini sebagai bukti pembayaran"
        android:textColor="#9E9E9E"
        android:textSize="11sp"
        android:layout_marginTop="2dp" />

</LinearLayout>
